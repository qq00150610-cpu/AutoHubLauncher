<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.AutoHub" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="android:colorPrimary">@color/primary_blue</item>
        <item name="android:colorPrimaryDark">@color/primary_blue_dark</item>
        <item name="android:colorAccent">@color/secondary_pink</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <!-- Navigation bar color. -->
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Background color. -->
        <item name="android:windowBackground">@color/background_light</item>

        <!-- Text colors. -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Window transitions. -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="Theme.AutoHub.Launcher" parent="Theme.AutoHub">
        <!-- Launcher-specific settings -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="Theme.AutoHub.Dark" parent="android:Theme.Material.NoActionBar">
        <!-- Primary brand color. -->
        <item name="android:colorPrimary">@color/primary_blue</item>
        <item name="android:colorPrimaryDark">@color/primary_blue_dark</item>
        <item name="android:colorAccent">@color/secondary_pink</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Navigation bar color. -->
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Background color. -->
        <item name="android:windowBackground">@color/background_dark</item>

        <!-- Text colors. -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
</resources>
