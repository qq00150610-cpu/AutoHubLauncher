<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/floating_ball_hit_size"
    android:layout_height="@dimen/floating_ball_hit_size"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <ImageView
        android:id="@+id/floating_ball_image"
        android:layout_width="@dimen/floating_ball_size"
        android:layout_height="@dimen/floating_ball_size"
        android:layout_gravity="center"
        android:src="@drawable/ic_floating_ball"
        android:background="@drawable/floating_ball_background"
        android:contentDescription="@string/floating_ball" />

</FrameLayout>
